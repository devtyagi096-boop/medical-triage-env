# ============================================================
# Medical Triage Environment - Environment Variables
# ============================================================

# REQUIRED: Hugging Face API Token
HF_TOKEN=your_huggingface_token_here

# OPTIONAL: API Configuration (defaults shown)
API_BASE_URL=https://api-inference.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# OPTIONAL: Task Configuration
TASK_NAME=medical-triage
BENCHMARK=emergency-dept
NUM_EPISODES=3
MAX_STEPS=30

# OPTIONAL: Debugging
VERBOSE=false
